{
  "name": "qwen2api",
  "version": "2026.04.14.09.30",
  "main": "src/server.js",
  "scripts": {
    "frontend:install": "pnpm --dir public install",
    "frontend:build": "pnpm --dir public build",
    "prepare:web": "pnpm run frontend:install && pnpm run frontend:build",
    "start": "pnpm run prepare:web && node src/start.js",
    "dev": "pnpm run prepare:web && nodemon src/server.js",
    "pm2": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop qwen2api",
    "pm2:restart": "pm2 restart qwen2api",
    "pm2:reload": "pm2 reload qwen2api",
    "pm2:delete": "pm2 delete qwen2api",
    "pm2:logs": "pm2 logs qwen2api",
    "pm2:status": "pm2 status",
    "pm2:monit": "pm2 monit"
  },
